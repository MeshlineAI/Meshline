# Meshline frontend env
# Production backend (also used for local dev — there is no separate local backend)
NEXT_PUBLIC_API_URL=https://meshline-backend-latest.onrender.com
# Public Base RPC, used client-side to classify an address as contract vs wallet (eth_getCode)
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
# Public site origin (used for share links / canonical URLs)
NEXT_PUBLIC_SITE_URL=https://meshline.io
